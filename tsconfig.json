{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": ["runtime/**/*.ts", "tools/**/*.ts", "agent/**/*.ts", "schema/**/*.ts", "memory/**/*.ts", "llm/**/*.ts", "skills/**/*.ts", "tests/**/*.ts", "scripts/**/*.ts", "config.ts"]
}
